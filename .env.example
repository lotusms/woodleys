# Woodley's Jewelers — environment variables

# Public site URL (used for metadata and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://woodleyjewelers.com

# Shopify Storefront API — single checkout experience
# SHOPIFY_STORE_DOMAIN=woodleyjewelers.myshopify.com
# SHOPIFY_STOREFRONT_ACCESS_TOKEN=your_storefront_access_token

# Stuller catalog embed (Shop All page)
# NEXT_PUBLIC_STULLER_EMBED_URL=https://your-stuller-embed-url

# Firestore database id (optional — account/order features)
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=main

# Firebase Admin (local scripts / tooling only)
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/serviceAccount.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Appointment / notification email (optional)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=info@woodleyjewelers.com
# SMTP_PASS=...
# SMTP_FROM="Woodley's Jewelers <info@woodleyjewelers.com>"
