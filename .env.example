# Woodley's Jewelers — environment variables

# Public site URL (used for metadata and canonical URLs)
NEXT_PUBLIC_SITE_URL=https://woodleyjewelers.com

# Shopify Storefront API (custom app via dev.shopify.com — see docs/SHOPIFY_DEV_SETUP.md)
SHOPIFY_STORE_DOMAIN=lotus-jewelery.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# Set to true only when Storefront API catalog reads are live (Basic+ plan + Headless).
# Leave unset/false to use Firestore inventory from the dashboard instead.
# SHOPIFY_CATALOG_ENABLED=true
# Server-only: used by pnpm shopify:storefront-token (do not expose to browser)
# SHOPIFY_CLIENT_ID=
# SHOPIFY_CLIENT_SECRET=

# Firebase web app (client SDK) — Firebase Console → Project settings → Your apps
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firestore database id (optional — account/order features)
NEXT_PUBLIC_FIRESTORE_DATABASE_ID=main

# Firebase Admin (local scripts + dashboard server API)
# 1. Download key: https://console.firebase.google.com/project/woodleys-3c319/settings/serviceaccounts/adminsdk
# 2. Run: pnpm setup:firebase-admin ~/Downloads/woodleys-3c319-firebase-adminsdk-xxxxx.json
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/.secrets/firebase-service-account.json
# Vercel production: FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# Address autocomplete (Geoapify — free tier: https://myprojects.geoapify.com/)
# GEOAPIFY_API_KEY=
# Optional proximity bias for local results (lon,lat) — Beaumont, CA example:
# GEOAPIFY_BIAS_PROXIMITY=-116.9772,33.9295

# Optional: Mapbox geocoding fallback when Geoapify is unavailable
# MAPBOX_ACCESS_TOKEN=
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=info@woodleyjewelers.com
# SMTP_PASS=...
# SMTP_FROM="Woodley's Jewelers <info@woodleyjewelers.com>"
