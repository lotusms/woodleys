{
  "name": "woodleys-jewelers",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20.9.0"
  },
  "browserslist": [
    "chrome >= 111",
    "edge >= 111",
    "firefox >= 111",
    "safari >= 16.4"
  ],
  "scripts": {
    "dev": "open http://localhost:3002 >/dev/null 2>&1 || true; WATCHPACK_POLLING=true CHOKIDAR_USEPOLLING=true next dev --port 3002 --webpack",
    "build": "next build",
    "start": "next start --port 3002",
    "lint": "eslint",
    "set:admin": "node scripts/set-admin-role.mjs",
    "seed:admin": "node scripts/seed-admin-firestore.mjs",
    "setup:firebase-admin": "node scripts/setup-firebase-admin-env.mjs",
    "verify:firebase-admin": "node --env-file=.env.local scripts/verify-firebase-admin.mjs",
    "seed:products": "node --env-file=.env.local scripts/seed-catalog-products.mjs",
    "firebase:deploy:firestore:main": "firebase deploy --only firestore:main",
    "shopify:storefront-token": "node scripts/shopify-create-storefront-token.mjs",
    "optimize:images": "node scripts/convert-product-images-webp.mjs"
  },
  "dependencies": {
    "@headlessui/react": "^2.2.9",
    "@heroicons/react": "^2.2.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^13.7.0",
    "jspdf": "^4.2.1",
    "next": "16.2.1",
    "nodemailer": "^8.0.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-icons": "^5.6.0",
    "recharts": "^3.9.0",
    "sharp": "^0.35.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "eslint": "^9",
    "eslint-config-next": "16.2.1",
    "firebase-tools": "^15",
    "tailwindcss": "^4"
  }
}
