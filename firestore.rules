rules_version = '2';
// Database: `main`. Deploy with: pnpm firebase:deploy:firestore:main (not `firebase deploy --only firestore:rules`, which may skip named DBs).
// Create the DB in Console → Firestore → Databases if needed.
service cloud.firestore {
  match /databases/{database}/documents {
    // Orders are written client-side after checkout completes.
    match /orders/{orderId} {
      // Public write is convenient for guest checkout. Restrict shape/size.
      allow create, update: if
        request.resource.data.id is string &&
        request.resource.data.id == orderId &&
        request.resource.data.email is string &&
        request.resource.data.totalUsd is number &&
        request.resource.data.lines is list &&
        request.resource.data.lines.size() > 0 &&
        request.resource.data.lines.size() <= 50;

      // Signed-in users can read orders whose email matches their Auth email (dashboard).
      allow read: if request.auth != null
        && request.auth.token.email != null
        && resource.data.email == request.auth.token.email;

      allow delete: if false;
    }

    // User profiles: document id = Firebase Auth uid. Initial create from signed-in client (empty orders only).
    // Cloud Functions may still upsert the same shape with Admin SDK.
    match /useraccounts/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.admin == false
        && request.resource.data.guest == false
        && request.resource.data.orderHistory is list
        && request.resource.data.orderHistory.size() == 0
        && request.resource.data.orderDetails is map
        && request.resource.data.orderDetails.keys().size() == 0
        && (!('phone' in request.resource.data) || request.resource.data.phone is string)
        && (!('shippingAddress' in request.resource.data) || request.resource.data.shippingAddress is map);
      // Profile updates (e.g. checkout registration merge) — immutable order/admin fields.
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == resource.data.email
        && request.resource.data.admin == resource.data.admin
        // guest flag immutable; treat missing guest as false (legacy docs before migration)
        && (request.resource.data.guest == resource.data.guest
          || (!resource.data.keys().hasAny(['guest']) && request.resource.data.guest == false))
        && request.resource.data.orderHistory == resource.data.orderHistory
        && request.resource.data.orderDetails == resource.data.orderDetails
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && (!('phone' in request.resource.data) || request.resource.data.phone is string)
        && (!('shippingAddress' in request.resource.data) || request.resource.data.shippingAddress is map);
      allow delete: if false;
    }
  }
}
