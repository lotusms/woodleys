rules_version = '2';
// Database: `main`. Deploy with: pnpm firebase:deploy:firestore:main (not `firebase deploy --only firestore:rules`, which may skip named DBs).
// Create the DB in Console → Firestore → Databases if needed.
service cloud.firestore {
  match /databases/{database}/documents {
    function isShopAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/useraccounts/$(request.auth.uid))
        && get(/databases/$(database)/documents/useraccounts/$(request.auth.uid)).data.admin == true
        && (
          !get(/databases/$(database)/documents/useraccounts/$(request.auth.uid)).data.keys().hasAny(['guest'])
          || get(/databases/$(database)/documents/useraccounts/$(request.auth.uid)).data.guest == false
        );
    }

    // Orders are written client-side after checkout completes.
    match /orders/{orderId} {
      // Public write is convenient for guest checkout. Restrict shape/size.
      allow create, update: if
        request.resource.data.id is string &&
        request.resource.data.id == orderId &&
        request.resource.data.email is string &&
        request.resource.data.totalUsd is number &&
        request.resource.data.lines is list &&
        request.resource.data.lines.size() > 0 &&
        request.resource.data.lines.size() <= 50;

      // Signed-in users can read orders whose email matches their Auth email (dashboard).
      allow read: if request.auth != null
        && request.auth.token.email != null
        && resource.data.email == request.auth.token.email;

      allow delete: if false;
    }

    // Storefront catalog — public read; admin writes from signed-in shop administrators.
    match /products/{productId} {
      allow read: if true;
      allow create: if isShopAdmin()
        && request.resource.data.handle == productId
        && request.resource.data.title is string
        && request.resource.data.priceUsd is number
        && request.resource.data.quantity is number
        && request.resource.data.active is bool
        && request.resource.data.featured is bool
        && request.resource.data.collectionHandles is list;
      allow update: if isShopAdmin()
        && request.resource.data.handle == resource.data.handle
        && request.resource.data.title is string;
      allow delete: if isShopAdmin();
    }

    match /catalogCollections/{collectionId} {
      allow read: if true;
      allow write: if isShopAdmin();
    }

    // Integration secrets — server (Admin SDK) only; dashboard uses /api/admin/settings.
    match /siteSettings/{docId} {
      allow read, write: if false;
    }

    // User profiles: document id = Firebase Auth uid. Initial create from signed-in client (empty orders only).
    // Cloud Functions may still upsert the same shape with Admin SDK.
    match /useraccounts/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == userId
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && request.resource.data.admin == false
        && request.resource.data.guest == false
        && request.resource.data.orderHistory is list
        && request.resource.data.orderHistory.size() == 0
        && request.resource.data.orderDetails is map
        && request.resource.data.orderDetails.keys().size() == 0
        && (!('phone' in request.resource.data) || request.resource.data.phone is string)
        && (!('shippingAddress' in request.resource.data) || request.resource.data.shippingAddress is map)
        && (!('billingSameAsShipping' in request.resource.data) || request.resource.data.billingSameAsShipping is bool)
        && (!('billingAddress' in request.resource.data) || request.resource.data.billingAddress is map);
      // Profile updates (e.g. checkout registration merge) — immutable order/admin fields.
      allow update: if request.auth != null && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.admin == resource.data.admin
        // guest flag immutable; treat missing guest as false (legacy docs before migration)
        && (request.resource.data.guest == resource.data.guest
          || (!resource.data.keys().hasAny(['guest']) && request.resource.data.guest == false))
        && request.resource.data.orderHistory == resource.data.orderHistory
        && request.resource.data.orderDetails == resource.data.orderDetails
        && request.resource.data.firstName is string
        && request.resource.data.lastName is string
        && (!('phone' in request.resource.data) || request.resource.data.phone is string)
        && (!('shippingAddress' in request.resource.data) || request.resource.data.shippingAddress is map)
        && (!('billingSameAsShipping' in request.resource.data) || request.resource.data.billingSameAsShipping is bool)
        && (!('billingAddress' in request.resource.data) || request.resource.data.billingAddress is map);
      allow delete: if false;
    }
  }
}
