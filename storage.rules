rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read so Next.js and `<Image src={downloadURL}>` can load studio assets
    // without Firebase Auth. Tighten to `match /public/{path=**}` if you move uploads.
    match /{path=**} {
      allow read: if true;
      // Only signed-in accounts may upload; lock to admin (e.g. custom claim) when ready.
      allow write: if request.auth != null;
    }
  }
}
